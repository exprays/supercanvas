# ─────────────────────────────────────────────
# SuperCanvas Environment Variables
# Copy this to .env.local and fill in your values
# All services use FREE TIERS
# ─────────────────────────────────────────────

# ── PostgreSQL (Neon - Free Tier) ──
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/supercanvas?sslmode=require"

# ── Clerk Auth (Free Tier - 10K MAU) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
CLERK_WEBHOOK_SECRET="whsec_xxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ── Convex (Free Tier - 1M function calls/month) ──
NEXT_PUBLIC_CONVEX_URL="https://xxx.convex.cloud"
CONVEX_DEPLOY_KEY="prod:xxx"

# ── Upstash Redis (Free Tier - 10K commands/day) ──
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxx"

# ── Cloudflare R2 (Free Tier - 10GB) ──
R2_ACCOUNT_ID="xxx"
R2_ACCESS_KEY_ID="xxx"
R2_SECRET_ACCESS_KEY="xxx"
R2_BUCKET_NAME="supercanvas-artifacts"
R2_PUBLIC_URL="https://xxx.r2.dev"

# ── Inngest (Free Tier - 5K events/month) ──
INNGEST_EVENT_KEY="xxx"
INNGEST_SIGNING_KEY="signkey-xxx"

# ── Redpanda Cloud (Free Tier) ──
REDPANDA_BROKERS="seed-xxx.redpanda.com:9092"
REDPANDA_USERNAME="xxx"
REDPANDA_PASSWORD="xxx"
REDPANDA_SECURITY_PROTOCOL="SASL_SSL"
REDPANDA_SASL_MECHANISM="SCRAM-SHA-256"
