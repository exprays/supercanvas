{
  "name": "supercanvas",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "inngest": "npx inngest-cli@latest dev",
    "db:generate": "pnpm --filter @supercanvas/db generate",
    "db:migrate": "pnpm --filter @supercanvas/db migrate",
    "db:push": "pnpm --filter @supercanvas/db push",
    "db:studio": "pnpm --filter @supercanvas/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.38.4"
    }
  }
}
